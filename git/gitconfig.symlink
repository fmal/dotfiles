[core]
  excludesfile = ~/.gitignore
  # Treat spaces before tabs, lines that are indented with 8 or more spaces,
  # and all kinds of trailing whitespace as an error
  whitespace = space-before-tab,indent-with-non-tab,trailing-space
  editor = code -w
  quotepath = false
  pager = diff-so-fancy | less --tabs=4 -RFX

[pull]
  rebase = true

[push]
  default = simple

[diff]
  algorithm = histogram
  colorMoved = plain

[interactive]
  diffFilter = diff-so-fancy --patch

[merge]
  # show the base in conflict markers for easier resolution
  conflictStyle = zdiff3

[rebase]
  autoStash = true
  autoSquash = true

[rerere]
  # remember conflict resolutions across rebases
  enabled = true

[fetch]
  # drop deleted remote branches on fetch
  prune = true

[commit]
  # show diff in the commit-message editor
  verbose = true

[branch]
  # list branches by most recent commit
  sort = -committerdate

[tag]
  # natural version sort (v1.10 after v1.9)
  sort = version:refname

[alias]
  s = status -sb
  uncommit = reset --soft HEAD^
  decommit = reset --hard HEAD^
  unstage = reset HEAD
  discard = checkout --
  difflast = diff HEAD^
  diffstaged = diff --cached
  dft = -c diff.external=difft diff
  last = log -1 HEAD --stat --abbrev-commit
  lg = log --graph --pretty=format:'%C(bold green)%h%Creset -%C(magenta)%d%Creset %s %C(dim white)(%cr)%Creset %C(cyan)<%an>%Creset'
  log1 = log --oneline --max-count=15

[color "diff"]
  meta = yellow bold
  commit = green bold
  frag = magenta bold
  old = red bold
  new = green bold
  whitespace = red reverse

[color "diff-highlight"]
  oldNormal = red bold
  oldHighlight = red bold 52
  newNormal = green bold
  newHighlight = green bold 22

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[init]
  defaultBranch = main

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

# use separate file for username / github token etc
#   git config -f ~/.gitconfig.local user.name John Appleseed
#   git config -f ~/.gitconfig.local user.email me@example.com
[include]
  path = ~/.gitconfig.local

[gtr "editor"]
  default = vscode
[gtr "ai"]
  default = claude
